{
  "name": "mobile-workout",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "frontend": "npm run start --prefix frontend",
    "frontend:android": "npm run android --prefix frontend",
    "frontend:ios": "npm run ios --prefix frontend",
    "frontend:web": "npm run web --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "lint:fix": "npm run lint:fix --prefix frontend",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .prettierignore",
    "type-check": "npm run type-check --prefix frontend",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "bash -c 'cd frontend && npx expo lint --fix'"
    ],
    "**/*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
